JAVA SOLUTION:
class Solution {
    public int findGCD(int[] nums) {

        Arrays.sort(nums);
        int min=nums[0];
        int n=nums.length;
        int max=nums[n - 1];
        int gcd=1;
        for(int i=1;i<=min;i++)
        {
            if(min%i==0&&max%i==0)gcd=i;
        }
        return gcd;
    }
}

C++ SOLUTION:
class Solution {
public:
    int findGCD(vector<int>& nums) {
        sort(nums.begin(),nums.end());
        int min=nums[0];
        int max=nums[nums.size()-1];
        int gcd=1;
        for(int i=1;i<=min;i++)
        {
            if(min%i==0&&max%i==0)gcd=i;
        }
        return gcd;
    }
};
